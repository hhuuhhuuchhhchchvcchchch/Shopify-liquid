<style>
  .custom-category-section-{{ section.id }}{
    display:flex;
    justify-content:center;
    align-items:center;
    flex-direction:column;
    text-align:center;
    gap: 1rem ;
    padding-top:{{section.settings.padding_top}}px;
    padding-bottom:{{section.settings.padding_bottom}}px;
  }
  .section-heading-{{section.id}}{
    font-family: var(--font-heading-family);
    letter-spacing: calc(var(--font-heading-scale) * .06rem);
    font-weight:400;
    font-size: 3rem;
  }
  .custom-category-wrapper-{{ section.id }}{
    display:flex;
    justify-content:center;
    gap:1.9rem;
    padding:20px 0;
    align-items:center;
  }

  .custom-category-{{ section.id }}{
    width:80%;
    height:auto;
    display:flex;
    overflow-x:auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    position:relative;
  }
  .custom-category-{{ section.id }}::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 10%;
    height: 100%;
    pointer-events: none;
    background: linear-gradient(
        to left,
        rgba(255, 255, 255, 0),
        rgba(255,255,255,0.6)
      );;
    }
  .custom-category-{{ section.id }}::after {
      content: "";
      position: absolute;
      top: 0;
      right: 0;
      width: 10%;
      height: 100%;
      pointer-events: none;
      background: linear-gradient(
          to right,
          rgba(255, 255, 255, 0),
          rgba(255,255,255,0.6)
    );
  }
  .custom-category-container-{{ section.id }}::-webkit-scrollbar{
    display: none;
  }
  .custom-category-container-{{ section.id }}{
    display:flex;
    justify-content:flex-start;
    align-items:center;
    gap:2rem;
    padding:2rem;
    overflow-x:scroll;

  }
  .custom-category-slide{
    flex: 0 0 33%;
    aspect-ratio:1;
    overflow: hidden;
    transition:all 0.5s ease;
  }
  .custom-category-slide img{
    height:100%;
    width:100%;
    object-fit:cover;
    user-select: none;
    -webkit-user-drag: none;
    -moz-user-select: none;
    -ms-user-select: none;
    pointer-events: auto;
  }
  .buttons{
    width:100%;
    max-width:{{ section.settings.section_width }}px;
    display:flex;
    justify-content:center;
    align-items:center;
    gap:20rem;
  }
  .custom-category-container-{{ section.id }}:hover .custom-category-slide:not(:hover){
    filter:blur(10px);
  }
  .slider-button-{{ section.id }}{
        width:auto;
        height:auto;
        border:none;
        background:transparent;
      }
      .icon{
        height:20px;
        width:20px;
      }
     @media (max-width: 768px) {
      .section-heading-{{section.id}}{
        font-size:2rem;
        letter-spacing: calc(var(--font-heading-scale) * .06rem);
        font-family: var(--font-heading-family);
      }
      .custom-category-wrapper-{{ section.id }}{
        gap:1rem;
      }
      .custom-category-container-{{ section.id }}{
        padding:1rem;
      }
      .custom-category-slide{
        flex: 0 0 90%;
        aspect-ratio:1;
        overflow: hidden;
    }
    .icon{
      height:12px;
      width:12px;
    }
    }
</style>
{% comment %}
  TODO:
  add collection name and hover animation for this section, completed by the shift  LOL
{% endcomment %}
<section class="custom-category-section-{{ section.id }}">
  <h2 class="section-heading-{{section.id}}">
    {{ section.settings.section_heading }}
  </h2>
  <div class="custom-category-wrapper-{{ section.id }}">
    <button class="slider-button-{{ section.id }} prevslide">
      <svg
        class="icon"
        width="256px"
        height="256px"
        viewBox="0 0 1024 1024"
        version="1.1"
        xmlns="http://www.w3.org/2000/svg"
        fill="{{ section.settings.arrow_color }}"
      >
        <path d="M768 903.232l-50.432 56.768L256 512l461.568-448 50.432 56.768L364.928 512z" />
      </svg>
    </button>
    <div class="custom-category-{{ section.id }}">
      <div class="custom-category-container-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="custom-category-slide">
            {% if block.settings.collection_image != blank %}
              {% assign image = block.settings.collection_image %}

              {% assign  widths =  '50, 75, 100, 150, 200, 300, 400, 500, 750, 1000, 1250, 1500, 1750, 2000' %}
              <a href="{{ block.settings.collection.url }}">
                {{
                  image
                  | image_url: width: image.width    
                  | image_tag:
                    loading: 'lazy',
                    widths: widths,
                    sizes: '(min-width: 1180px) 33vw, (min-width: 990px) 40vw, (min-width: 750px) 50vw, 100vw'
                }}
              </a>

            {% else %}
              {{
                collection.featured_image
                | image_url: width: 400
                | image_tag:
                  loading: 'lazy',
                  class: 'product-image',
                  widths: '400, 500, 600, 700, 800, 900, 1000, 1100, 1200',
                  sizes: '(min-width: 768px)  400px, 100vw'
              }}
            {% endif %}

            {% if block.settings.collection_name != blank %}
              <h3>{{ block.settings.collection_name }}</h3>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
    <button class="slider-button-{{ section.id }} nextslide">
      <svg
        class="icon"
        width="256px"
        height="256px"
        viewBox="0 0 1024 1024"
        version="1.1"
        xmlns="http://www.w3.org/2000/svg"
        fill="{{ section.settings.arrow_color }}"
      >
        <g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"><path d="M256 120.768L306.432 64 768 512l-461.568 448L256 903.232 659.072 512z" fill="{{ section.settings.arrow_color }}"></path></g>
      </svg>
    </button>
  </div>
</section>
<script src="{{ 'custom-category_slider.js' | asset_url}}" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('.custom-category-wrapper-{{ section.id }}');
    if (!section) return;

    new Slider({
      prev: section.querySelector('.prevslide'),
      next: section.querySelector('.nextslide'),
      slider: section.querySelector('.custom-category-container-{{ section.id }}'),
      scrollAmount: 500,
      time: 1.3,
      auto: true,
      autoSpeed: 100,
    });
  });
</script>
{% schema %}
{
  "name": "custom category grid",
  "settings": [
    {
      "type": "header",
      "content": "section padding"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "section heading",
      "default": "Collection List"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 12,
      "max": 120,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 12,
      "max": 120,
      "step": 4,
      "default": 48
    }
  ],
  "blocks": [
    {
      "name": "collection ",
      "type": "block",
      "limit": 10,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "image_picker",
          "id": "collection_image",
          "label": "Collection Image"
        },
        {
          "type": "text",
          "id": "collection_name",
          "label": "Collection name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "custom category section"
    }
  ]
}
{% endschema %}
