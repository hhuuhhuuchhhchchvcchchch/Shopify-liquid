<style>
    .blog-section-{{ section.id }} {
      width: 100%;
      max-width: 1600px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 3fr 1fr;
      gap: 40px;
      padding: 80px 40px;
    }


    .blog-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(100%, 400px), 1fr));
      gap: 32px;
    }

    @media (max-width: 640px) {
      .blog-grid {
        grid-template-columns: 1fr 1fr;
        gap: 20px;
      }
    }

    .blogs-container {
      display: flex;
      flex-direction: column;
    }

    .blog-featured {
      margin-bottom: 2rem;
    }

    .aside-panel {
    flex: none;
    display: flex;
    flex-direction: column;
    text-align: center;
    height: fit-content;
    padding: 24px;
    border-radius: 2rem;
    background: #f4f4f4;

    align-items: center; /* keeps items centered */
  }

  .blog-image img,
  .blog-icon img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .blog-image {
    width: 100%;
  }

    .aside-panel p {
      font-size: 16px;
      color: #333;
    }
    .line-cut{
      width: 100%;
      height: 1px;
      margin: 0px;
    }

    .blog-featured,
    .blog-grid > div {
      filter: blur(10px);
      opacity: 0;
      transform: translateY(-20px);
      transition: all 0.5s ease-out;
      will-change: opacity, transform, filter;
    }

    .blog-featured.visible,
    .blog-grid > div.visible {
      filter: blur(0px);
      opacity: 1;
      transform: translateY(0);
    }  @media (max-width: 1024px) {
      .blog-section-{{ section.id }} {
        grid-template-columns: 1fr;
        padding: 48px 24px;
        gap: 32px;
      }

    }


    @media (max-width: 640px) {
      .blog-section-{{ section.id }} {
        padding: 32px 16px;
        gap: 24px;
      }
    }
</style>
<style>
    .blog-icon-text,
  .blog-icon-list{
    display:flex;
    align-items:center;
    gap:10px;
  }

  .blog-icon-text img,
  .blog-icon-list img{
    aspect-ratio: 1;
    width: 24px;
  }
    {% for block in section.blocks %}

      .block-{{ block.id }} {
        margin-top: {{ block.settings.margin_top }}px;
        margin-bottom: {{ block.settings.margin_bottom }}px;
        width:100%;
        max-width: {{ block.settings.width }}px;
      }
      {% if block.type == 'image' %}
      .block-{{ block.id }} {
        border-radius:0.5rem;
      }
      {% endif %}
      {% if block.type == 'richtext' %}
        .block-{{ block.id }}{
          text-align:left;
        }
        {% endif %}

      {% if block.type == 'text' %}
      .block-{{ block.id }} {
        color: {{ block.settings.color }};
      }
      {% endif %}

      {% if block.type == 'divider' %}
      .block-{{ block.id }} {
        border: none;
        height: 1px;
        background: {{ block.settings.color }};
      }
      {% endif %}

    {% endfor %}
</style>
{% assign first_article = blog.articles.first %}

<section class="blog-section blog-section-{{ section.id }}">
  <div class="blogs-container">
    <div class="blog-featured">
      {% render 'article-custom-card', blog: blog, article: first_article, featured: true %}
    </div>

    <div class="blog-grid">
      {% for article in blog.articles offset: 1 %}
        {% render 'article-custom-card', blog: blog, article: article %}
      {% endfor %}
    </div>
  </div>

  {% comment %} <aside class="aside-panel">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'image' %}
          <div class="blog-image block-{{ block.id }}">
            <img src="{{ block.settings.image | image_url }}" alt="">
          </div>

        {% when 'icon' %}
          <div class="blog-icon block-{{ block.id }}">
            <img src="{{ block.settings.icon | image_url }}" alt="">
          </div>

        {% when 'text' %}
          <div class="blog-text block-{{ block.id }}">
            {{ block.settings.text }}
          </div>

        {% when 'divider' %}
          <hr class="block-{{ block.id }}">
        {% when 'richtext' %}
          <div class="blog-richtext block-{{ block.id }}">
            {{ block.settings.text }}
          </div>
          <style>
            .blog-richtext{
              text-align: left;
            }
          </style>

        {% when 'icon_text' %}
          <div class="blog-icon-text block-{{ block.id }}">
            <img src="{{ block.settings.icon | image_url }}" alt="">
            <span>{{ block.settings.text }}</span>
          </div>

        {% when 'icon_list' %}
          <div class="blog-icon-list block-{{ block.id }}">
            <img src="{{ block.settings.icon | image_url }}" alt="">
            <span>{{ block.settings.text }}</span>
          </div>
      {% endcase %}
    {% endfor %}
  </aside> {% endcomment %}
  {% render 'blog-aside-panel', section: section %}
</section>

<script>
  const animateItems = document.querySelectorAll('.blog-featured, .blog-grid > div');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.1, // ← was 0.4, too high for tall cards on small screens
      rootMargin: '0px 0px -40px 0px', // ← trigger slightly before fully in view
    }
  );

  animateItems.forEach((item) => observer.observe(item));
</script>
